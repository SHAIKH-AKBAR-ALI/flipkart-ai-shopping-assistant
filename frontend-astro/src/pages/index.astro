---
import Layout from '../layouts/Layout.astro';
import SiteFooter from '../components/SiteFooter.astro';

const faqs = [
  {
    q: 'What can I actually ask?',
    a: 'Anything you would ask a knowledgeable friend before buying: "best laptop under 60k for coding", "which of these has a better camera", "compare the first two", or "book the Samsung one". Sales, technical, and booking questions each get routed to the agent that handles them best.',
  },
  {
    q: 'Is this a real store? Do orders actually ship?',
    a: 'No. Flipkart Assist is a portfolio demo, not affiliated with Flipkart. The booking flow is complete — product selection, delivery details, a payment step — but the payment is a mock challenge and the confirmed order exists only inside your session.',
  },
  {
    q: 'Will I be asked for card details?',
    a: 'Never. The mock payment page asks you to solve a small arithmetic problem instead of entering payment credentials. No card number or UPI ID is ever requested, transmitted, or stored.',
  },
  {
    q: 'How do budget filters work?',
    a: 'Mention a budget in plain words — "under 50k", "between 20k and 35k", "above 30000" — and every later search in the conversation respects it. Name a new budget that contradicts the old one and the assistant starts fresh from the new range instead of mixing the two.',
  },
  {
    q: 'How do I compare products?',
    a: 'Tick the compare checkbox on two or three product cards and hit Compare, or just type "compare these". You get a side-by-side table plus a recommendation.',
  },
  {
    q: 'How do I start over or clear my data?',
    a: 'Click "New conversation" in any chat, or switch to a different category — either one discards the session and starts clean. Closing the tab clears the cached transcript from your browser too.',
  },
  {
    q: 'Where do the answers come from?',
    a: 'A retrieval pipeline searches a catalog of real product listings (hybrid vector + keyword search, reranked to the top four matches), and a language model writes the reply from what was found. When the catalog runs dry, external product APIs fill in live specs and prices.',
  },
];

const categories = [
  { slug: 'laptops', label: 'Laptops', blurb: 'Power for work, code, and everything after' },
  { slug: 'mobiles', label: 'Mobiles', blurb: 'Cameras, chipsets, and everyday carry' },
  { slug: 'tvs', label: 'TVs', blurb: 'Screens built for movie night' },
  { slug: 'refrigerators', label: 'Refrigerators', blurb: 'Cool, quiet, and built to last' },
  { slug: 'smart-watches', label: 'Smart Watches', blurb: 'Fitness and notifications on your wrist' },
  { slug: 'washing-machines', label: 'Washing Machines', blurb: 'Laundry day, simplified' },
];
---

<Layout title="Flipkart Assist — Shop with an expert, not a search bar">
	<main class="mx-auto flex min-h-screen max-w-5xl flex-col px-6 py-16 sm:py-24">
		<header class="mb-16 max-w-2xl">
			<p class="mb-4 font-body text-sm font-medium uppercase tracking-widest text-coral">
				Flipkart Assist
			</p>
			<h1 class="font-display text-4xl leading-tight text-ink sm:text-5xl">
				Shop like you've got a friend who knows the specs.
			</h1>
			<p class="mt-5 text-lg leading-relaxed text-ink-soft">
				Ask about pricing, compare features, or just say the word and we'll get it booked.
				Our sales, technical, and booking agents work the conversation together — pick a
				category to start.
			</p>
		</header>

		<section aria-label="Product categories">
			<h2 class="mb-6 font-display text-xl text-ink-soft">What are you shopping for?</h2>
			<div class="grid grid-cols-1 gap-4 sm:grid-cols-2 md:grid-cols-3">
				{categories.map((c) => (
					<a
						href={`/chat/${c.slug}`}
						data-category-card
						class="category-card group rounded-2xl border border-border-soft bg-paper p-6 transition-colors hover:border-coral hover:bg-coral-soft/40"
					>
						<h3 class="font-display text-xl text-ink group-hover:text-coral-dark">
							{c.label}
						</h3>
						<p class="mt-2 text-sm text-ink-soft">{c.blurb}</p>
						<span class="mt-4 inline-block text-sm font-medium text-coral group-hover:translate-x-1 transition-transform">
							Start chatting →
						</span>
					</a>
				))}
			</div>
		</section>

		<section id="faq" aria-label="Frequently asked questions" class="mt-20">
			<h2 class="mb-6 font-display text-xl text-ink-soft">Questions people ask first</h2>
			<div class="divide-y divide-border-soft rounded-2xl border border-border-soft bg-paper">
				{faqs.map((f) => (
					<details class="faq-item group px-6 py-4">
						<summary class="flex cursor-pointer list-none items-baseline justify-between gap-4 font-medium text-ink transition-colors hover:text-coral-dark">
							{f.q}
							<span class="faq-marker shrink-0 text-coral transition-transform" aria-hidden="true">+</span>
						</summary>
						<p class="mt-3 max-w-2xl text-sm leading-relaxed text-ink-soft">{f.a}</p>
					</details>
				))}
			</div>
		</section>

		<SiteFooter />
	</main>

	<style>
		@keyframes card-wiggle {
			0% { transform: rotate(0deg); }
			25% { transform: rotate(-1deg); }
			75% { transform: rotate(1deg); }
			100% { transform: rotate(0deg); }
		}
		.category-card:hover {
			animation: card-wiggle 0.3s ease;
		}
		.category-card.is-clicking {
			animation: card-click 150ms ease;
		}
		@keyframes card-click {
			0% { transform: scale(1); }
			50% { transform: scale(0.95); }
			100% { transform: scale(1); }
		}
		.faq-item summary::-webkit-details-marker {
			display: none;
		}
		.faq-item[open] .faq-marker {
			transform: rotate(45deg);
		}
		@media (prefers-reduced-motion: reduce) {
			.category-card:hover,
			.category-card.is-clicking {
				animation: none;
			}
			.faq-marker {
				transition: none;
			}
		}
	</style>

	<script>
		document.querySelectorAll('[data-category-card]').forEach((card) => {
			card.addEventListener('click', (e) => {
				e.preventDefault();
				if (card.classList.contains('is-clicking')) return;
				const href = card.getAttribute('href');
				card.classList.add('is-clicking');
				setTimeout(() => {
					window.location.href = href;
				}, 150);
			});
		});
	</script>
</Layout>
