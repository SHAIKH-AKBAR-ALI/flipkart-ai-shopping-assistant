---
import Layout from '../../layouts/Layout.astro';
import { CATEGORIES, categoryFromSlug } from '../../lib/categories.js';

export function getStaticPaths() {
  return CATEGORIES.map((c) => ({ params: { category: c.slug } }));
}

const { category: slug } = Astro.params;
const category = categoryFromSlug(slug);

if (!category) {
  return Astro.redirect('/');
}
---

<Layout title={`${category.label} — Flipkart Assist`}>
	<div class="mx-auto flex h-screen max-h-[100dvh] min-h-0 max-w-4xl flex-col px-4 py-4 [height:100dvh] sm:px-6 sm:py-6">
		<header class="mb-4 flex flex-col gap-3 border-b border-border-soft pb-4 sm:flex-row sm:items-center sm:justify-between">
			<div class="pr-12 sm:pr-0">
				<a href="/" class="text-xs font-medium uppercase tracking-widest text-coral hover:text-coral-dark">
					← Flipkart Assist
				</a>
				<h1 class="font-display text-xl text-ink sm:text-2xl">{category.label}</h1>
			</div>
			<div class="flex items-center gap-2 sm:gap-3">
				<label class="hidden text-xs text-ink-soft sm:inline" for="category-switch">Switch</label>
				<select
					id="category-switch"
					class="min-w-0 flex-1 rounded-lg border border-border-soft bg-paper px-2 py-1.5 text-sm text-ink focus:border-coral focus:outline-none sm:flex-none"
				>
					{CATEGORIES.map((c) => (
						<option value={c.slug} selected={c.slug === category.slug}>{c.label}</option>
					))}
				</select>
				<button
					id="new-conversation"
					class="shrink-0 whitespace-nowrap rounded-lg border border-border-soft bg-paper px-3 py-1.5 text-sm font-medium text-ink-soft transition-colors hover:border-coral hover:text-coral-dark"
				>
					New conversation
				</button>
			</div>
		</header>

		<div id="error-banner" class="mb-4 hidden items-center justify-between rounded-xl border border-red-200 bg-red-50 px-4 py-3 text-sm text-red-700">
			<span id="error-text"></span>
			<button id="error-retry" class="ml-4 shrink-0 rounded-lg border border-red-300 px-3 py-1 text-xs font-medium hover:bg-red-100">
				Retry
			</button>
		</div>

		<main id="chat-messages" class="min-h-0 flex-1 space-y-4 overflow-y-auto pb-4 pr-1"></main>

		<div id="typing-indicator" class="mb-2 hidden text-xs text-ink-soft">Assistant is typing…</div>

		<form id="chat-form" class="flex items-end gap-3 border-t border-border-soft pt-4">
			<textarea
				id="chat-input"
				rows="1"
				placeholder={`Ask about ${category.label.toLowerCase()}…`}
				class="flex-1 resize-none rounded-xl border border-border-soft bg-paper px-4 py-3 text-sm text-ink focus:border-coral focus:outline-none"
			></textarea>
			<button
				id="chat-send"
				type="submit"
				class="rounded-xl bg-coral px-5 py-3 text-sm font-medium text-white transition-colors hover:bg-coral-dark disabled:cursor-not-allowed disabled:opacity-60"
			>
				Send
			</button>
		</form>

		<div id="compare-bar" class="pointer-events-none fixed inset-x-0 bottom-24 z-40 hidden justify-center px-4 sm:bottom-6">
			<button
				id="compare-btn"
				type="button"
				disabled
				class="pointer-events-auto rounded-full bg-coral px-6 py-3 text-sm font-medium text-white shadow-lg transition-colors hover:bg-coral-dark disabled:cursor-not-allowed disabled:opacity-50"
			>
				Compare (0)
			</button>
		</div>
	</div>

	<div id="product-detail-overlay" class="fixed inset-0 z-40 hidden bg-ink/30"></div>
	<aside
		id="product-detail-panel"
		class="fixed right-0 top-0 z-50 h-full w-full max-w-sm translate-x-full transform bg-paper shadow-2xl transition-transform duration-[250ms] ease-out sm:max-w-md"
	>
		<div class="flex h-full flex-col overflow-y-auto p-6">
			<button id="detail-close-btn" aria-label="Close panel" class="self-end text-lg text-ink-soft hover:text-coral-dark">✕</button>
			<div id="detail-content" class="mt-2 flex-1"></div>
		</div>
	</aside>

	<script define:vars={{ categoryLabel: category.label, categorySlug: category.slug }}>
		window.__CHAT_CONTEXT__ = { categoryLabel, categorySlug };
	</script>
	<script>
		import { initChatApp } from '../../lib/chat-app.js';
		import { resetSessionId } from '../../lib/session.js';
		import { clearHistory } from '../../lib/history.js';
		import { deleteSession } from '../../lib/api.js';

		const { categoryLabel, categorySlug } = window.__CHAT_CONTEXT__;

		// Returning from the /payment page (?payment=success|failed) is NOT a
		// fresh visit — the in-progress booking lives in the current session
		// and the redirect handler needs to send payment_confirmed/failed to
		// it. Wiping the session here would drop the booking mid-flow (the
		// payment glitch). Only reset on a genuinely new visit.
		const returningFromPayment = /[?&]payment=(success|failed)/.test(window.location.search);
		// A refresh of the SAME category keeps the session and transcript
		// (restored from sessionStorage). Only switching to a different
		// category — or an explicit "New conversation" — starts fresh, so
		// state never bleeds across categories.
		const lastCategory = sessionStorage.getItem('flipkart_last_category');
		const categoryChanged = lastCategory !== categorySlug;
		if (!returningFromPayment && categoryChanged) {
			const previousSessionId = sessionStorage.getItem('flipkart_session_id');
			if (previousSessionId) {
				clearHistory(previousSessionId);
				deleteSession(previousSessionId).catch(() => {});
			}
			resetSessionId();
		}
		sessionStorage.setItem('flipkart_last_category', categorySlug);

		initChatApp({
			categoryLabel,
			categorySlug,
			seedMessage: `I'm looking for ${categoryLabel.toLowerCase()}.`,
		});

		document.getElementById('category-switch').addEventListener('change', (e) => {
			window.location.href = `/chat/${e.target.value}`;
		});

		const textarea = document.getElementById('chat-input');
		textarea.addEventListener('keydown', (e) => {
			if (e.key === 'Enter' && !e.shiftKey) {
				e.preventDefault();
				document.getElementById('chat-form').requestSubmit();
			}
		});
	</script>
</Layout>
