---
import Layout from './Layout.astro';
import SiteFooter from '../components/SiteFooter.astro';

interface Props {
  title: string;
  eyebrow: string;
  heading: string;
  intro?: string;
}

const { title, eyebrow, heading, intro } = Astro.props;
---

<Layout title={title}>
  <main class="mx-auto flex min-h-screen max-w-3xl flex-col px-6 py-16 sm:py-24">
    <a href="/" class="mb-10 inline-block text-sm font-medium text-coral transition-colors hover:text-coral-dark">
      ← Back to Flipkart Assist
    </a>

    <header class="mb-10">
      <p class="mb-4 font-body text-sm font-medium uppercase tracking-widest text-coral">
        {eyebrow}
      </p>
      <h1 class="font-display text-4xl leading-tight text-ink">{heading}</h1>
      {intro && <p class="mt-5 text-lg leading-relaxed text-ink-soft">{intro}</p>}
    </header>

    <div class="info-prose">
      <slot />
    </div>

    <SiteFooter />
  </main>
</Layout>

<style>
  .info-prose :global(h2) {
    font-family: var(--font-display);
    font-size: 1.375rem;
    color: var(--color-ink);
    margin-top: 2.5rem;
    margin-bottom: 0.75rem;
  }
  .info-prose :global(h2:first-child) {
    margin-top: 0;
  }
  .info-prose :global(p) {
    color: var(--color-ink-soft);
    line-height: 1.7;
    margin-bottom: 1rem;
  }
  .info-prose :global(ul) {
    color: var(--color-ink-soft);
    line-height: 1.7;
    margin-bottom: 1rem;
    padding-left: 1.25rem;
    list-style: disc;
  }
  .info-prose :global(li) {
    margin-bottom: 0.375rem;
  }
  .info-prose :global(li::marker) {
    color: var(--color-coral);
  }
  .info-prose :global(a) {
    color: var(--color-coral);
    text-decoration: underline;
    text-underline-offset: 3px;
  }
  .info-prose :global(a:hover) {
    color: var(--color-coral-dark);
  }
  .info-prose :global(strong) {
    color: var(--color-ink);
    font-weight: 600;
  }
</style>
